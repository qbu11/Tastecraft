{
  "$schema": "https://schema.zeabur.app/template.json",
  "name": "Tastecraft 品匠",
  "description": "AI-powered multi-platform content operations system",
  "services": [
    {
      "name": "postgres",
      "template": "POSTGRESQL"
    },
    {
      "name": "backend",
      "template": "GIT",
      "source": {
        "repoURL": "https://github.com/qbu11/Tastecraft",
        "branch": "master"
      },
      "configs": {
        "dockerfile": "Dockerfile"
      },
      "ports": [8000],
      "env": {
        "APP_ENV": "production",
        "API_HOST": "0.0.0.0",
        "API_PORT": "8000",
        "LOG_LEVEL": "INFO",
        "DATABASE_URL": "${POSTGRES_CONNECTION_STRING}",
        "CORS_ORIGINS": "https://${ZEABUR_WEB_URL}"
      }
    },
    {
      "name": "frontend",
      "template": "GIT",
      "source": {
        "repoURL": "https://github.com/qbu11/Tastecraft",
        "branch": "master",
        "rootDirectory": "frontend"
      },
      "configs": {
        "dockerfile": "Dockerfile"
      },
      "ports": [3000],
      "domainKey": "ZEABUR_WEB_URL"
    }
  ]
}
