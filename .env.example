# ============================================================
# LLM Provider Configuration
# ============================================================

# Anthropic (Claude) - Primary model for content creation
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (GPT) - For data analysis and light tasks
OPENAI_API_KEY=sk-xxx

# Optional: Use OpenAI-compatible endpoints (e.g., Azure, local)
# OPENAI_API_BASE=https://your-endpoint.openai.azure.com/
# OPENAI_API_VERSION=2024-02-15-preview

# ============================================================
# Platform API Credentials
# ============================================================

# Feishu (Lark) - Internal communication and content publishing
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Xiaohongshu (Little Red Book)
# Note: Requires OAuth flow for user authorization
XHS_APP_ID=xxx
XHS_APP_SECRET=xxx

# WeChat Official Account
WECHAT_APP_ID=xxx
WECHAT_APP_SECRET=xxx

# ============================================================
# Database Configuration
# ============================================================

# SQLite (MVP/Development)
DATABASE_URL=sqlite+aiosqlite:///./data/crew.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/crew_media

# ============================================================
# Application Settings
# ============================================================

# Environment: development, staging, production
APP_ENV=development

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Debug mode (disable in production)
DEBUG=true

# Secret key for session management
SECRET_KEY=your-secret-key-change-in-production

# ============================================================
# Logging Configuration
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to project root)
LOG_FILE=logs/crew.log

# ============================================================
# CrewAI Settings
# ============================================================

# Maximum iterations for agent execution
CREW_MAX_ITER=15

# Enable verbose output for debugging
CREW_VERBOSE=true

# Memory backend: local, redis
CREW_MEMORY_BACKEND=local

# ============================================================
# Scheduler Settings (APScheduler)
# ============================================================

# Enable scheduler
SCHEDULER_ENABLED=true

# Scheduler timezone
SCHEDULER_TIMEZONE=Asia/Shanghai

# ============================================================
# External Services
# ============================================================

# LangSmith (optional, for observability)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_xxx
# LANGCHAIN_PROJECT=crew-media-ops

# Redis (optional, for caching and memory)
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# Browser Automation (Playwright)
# ============================================================

# Headless mode (set to false for debugging)
PLAYWRIGHT_HEADLESS=true

# Browser timeout in milliseconds
PLAYWRIGHT_TIMEOUT=30000

# ============================================================
# Rate Limiting
# ============================================================

# API rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Platform posting rate limits
XHS_DAILY_POST_LIMIT=10
WECHAT_DAILY_POST_LIMIT=8

# ============================================================
# Content Settings
# ============================================================

# Default content language
DEFAULT_LANGUAGE=zh-CN

# Maximum content length by platform
MAX_CONTENT_LENGTH_XHS=1000
MAX_CONTENT_LENGTH_WECHAT=20000

# ============================================================
# Security
# ============================================================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# API key for internal service authentication
INTERNAL_API_KEY=your-internal-api-key

# JWT token expiration time in seconds (default: 24 hours)
JWT_EXPIRES_IN=86400

# Encryption key for sensitive data (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# IMPORTANT: Change this in production and keep it secret!
ENCRYPTION_KEY=your-fernet-encryption-key-here

# Enable audit logging for security events
AUDIT_LOGGING_ENABLED=true

# Rate limiting for API endpoints (requests per minute per IP)
API_RATE_LIMIT=60

# ============================================================
# Platform Cookies (Encrypted)
# ============================================================

# These are stored encrypted in the database, but can be set here for initial setup
# Cookie values will be encrypted before storage

# Xiaohongshu cookie (web session)
XHS_COOKIE=

# Weibo cookie
WEIBO_COOKIE=

# Zhihu cookie
ZHIHU_COOKIE=

# Douyin cookie
DOUYIN_COOKIE=

# Bilibili cookie
BILIBILI_COOKIE=
